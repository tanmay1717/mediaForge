<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    /* TODO: Add inline email styles — email clients don't support external CSS
       - Max-width container (600px)
       - Sans-serif font stack
       - Brand colors
       - Responsive padding
       - Button styles (background color, padding, border-radius)
       - Footer styles (smaller text, muted color) */
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; padding: 20px; background: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 40px; }
    .footer { margin-top: 32px; padding-top: 16px; border-top: 1px solid #eee; font-size: 12px; color: #999; }
  </style>
</head>
<body>
  <div class="container">
    {{{content}}}
    <div class="footer">
      <p>MediaForge — Self-hosted media delivery</p>
      <p>&copy; {{year}} Your Company</p>
    </div>
  </div>
</body>
</html>
